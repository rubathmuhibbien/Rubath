<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Database Alumni</title>

  <style>
    body {
      font-family: Arial;
      background: #f1f5f9;
      margin: 0;
    }

    header {
      background: #0ea5e9;
      color: white;
      padding: 20px;
      text-align: center;
    }

    .container {
      max-width: 1100px;
      margin: auto;
      padding: 30px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 20px;
    }

    .card {
      background: white;
      border-radius: 12px;
      padding: 15px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .name {
      font-weight: bold;
      font-size: 18px;
    }

    .info {
      font-size: 14px;
      color: #555;
      margin-top: 5px;
    }
  </style>
</head>
<body>

<header>
  <h1>Database Alumni</h1>
</header>

<div class="container">
  <div class="grid" id="alumniList"></div>
</div>

<script>
const apiURL = "LINK_WEB_APP_LU?action=getAlumni";

async function loadAlumni() {
  const res = await fetch(apiURL);
  const data = await res.json();

  const container = document.getElementById("alumniList");
  container.innerHTML = "";

  data.forEach(alumni => {
    const card = `
      <div class="card">
        <div class="name">${alumni.nama}</div>
        <div class="info">📍 ${alumni.domisili || '-'}</div>
        <div class="info">📅 ${alumni.tahun_masuk} - ${alumni.tahun_keluar}</div>
      </div>
    `;
    container.innerHTML += card;
  });
}

loadAlumni();
</script>

</body>
</html>
